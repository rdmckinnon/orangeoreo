---
interface Props {
  ticketType?: string;
  date?: string;
  doors?: string;
  section?: string;
  seat?: string;
  attendee?: string;
  ticketNumber?: string;
}

const {
  ticketType = "VIP ACCESS",
  date = "MAR 15",
  doors = "7:00 PM",
  section = "FLOOR",
  seat = "678",
  attendee = "YOUR NAME HERE",
  ticketNumber = "OO-2026-0315-FA12"
} = Astro.props;
---

<div class="ticket" id="ticket">
  <div class="ticket-header">
    <div class="ticket-band">ORANGE OREO</div>
    <div class="ticket-tour">CITRUS DREAMS WORLD TOUR 2026</div>
    <div class="ticket-type-badge" id="ticketTypeBadge">{ticketType}</div>
  </div>

  <div class="ticket-body">
    <div class="ticket-field">
      <div class="field-label">Date</div>
      <div class="field-value" id="ticketDate">{date}</div>
    </div>
    <div class="ticket-field">
      <div class="field-label">Doors</div>
      <div class="field-value" id="ticketDoors">{doors}</div>
    </div>
    <div class="ticket-field">
      <div class="field-label">Section</div>
      <div class="field-value" id="ticketSection">{section}</div>
    </div>
    <div class="ticket-field">
      <div class="field-label">Seat</div>
      <div class="field-value" id="ticketSeat">{seat}</div>
    </div>
  </div>

  <div class="ticket-attendee">
    <div class="attendee-info">
      <div class="attendee-label">Ticket Holder</div>
      <div class="attendee-name" id="ticketAttendee">{attendee}</div>
    </div>
    <div class="ticket-qr" id="ticketQR">
      <img id="qrImage" src="https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=ORANGE-OREO" alt="QR Code" width="60" height="60" />
    </div>
  </div>

  <div class="ticket-footer">
    <div class="barcode" id="barcode">
      <!-- Barcode bars will be generated by JS -->
    </div>
    <div class="ticket-number" id="ticketNumberDisplay">{ticketNumber}</div>
  </div>
</div>

<script is:inline>
  // Generate barcode
  function generateBarcode() {
    const barcode = document.getElementById('barcode');
    if (!barcode) return;
    barcode.innerHTML = '';
    for (let i = 0; i < 50; i++) {
      const bar = document.createElement('div');
      bar.className = 'bar';
      bar.style.height = (Math.random() * 20 + 25) + 'px';
      bar.style.width = (Math.random() > 0.6 ? 3 : 2) + 'px';
      barcode.appendChild(bar);
    }
  }

  // Generate QR code with ticket data using API
  window.generateQRCode = function(ticketData) {
    const qrImage = document.getElementById('qrImage');
    if (!qrImage) return;

    const data = encodeURIComponent(ticketData || 'https://orangeoreo.com');
    qrImage.src = `https://api.qrserver.com/v1/create-qr-code/?size=120x120&data=${data}`;
  }

  // Initialize on page load
  document.addEventListener('DOMContentLoaded', () => {
    generateBarcode();
  });
</script>
