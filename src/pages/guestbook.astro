---
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
---

<Layout title="Fan Wall" description="Leave a message for Orange Oreo">
  <!-- Header -->
  <header class="page-header">
    <div class="container" style="display: flex; align-items: center; justify-content: space-between;">
      <a href="/" class="page-logo">ORANGE <span>OREO</span></a>
      <a href="/tickets" class="page-badge" style="text-decoration: none;">GET TICKETS</a>
    </div>
  </header>

  <!-- Hero -->
  <div class="guestbook-hero">
    <div class="container">
      <h1>THE WALL</h1>
      <p>Leave a message for Addy & Emma. We read every single one.</p>
    </div>
  </div>

  <!-- Form -->
  <div class="guestbook-form-section">
    <div class="container">
      <form class="guestbook-form" id="guestbook-form">
        <input
          type="text"
          class="input"
          id="gb-name"
          placeholder="Your name"
          required
          maxlength="50"
        />
        <textarea
          id="gb-message"
          placeholder="Leave a message..."
          required
          maxlength="280"
        ></textarea>
        <button type="submit" class="btn btn-primary" id="gb-submit">POST TO THE WALL</button>
        <p class="gb-status" id="gb-status"></p>
      </form>
    </div>
  </div>

  <!-- Message Wall -->
  <div class="guestbook-wall">
    <div class="container">
      <div class="message-grid" id="message-grid">
        <div class="guestbook-empty" id="gb-empty">Loading messages...</div>
      </div>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  .gb-status {
    font-size: 0.9rem;
    min-height: 24px;
    text-align: center;
  }
  .gb-status.success {
    color: var(--sea-green-dark);
  }
  .gb-status.error {
    color: #e53935;
  }
  #gb-submit:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  .message-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: 12px;
  }

  .react-btn {
    background: transparent;
    border: none;
    outline: none;
    padding: 0;
    margin: 0;
    cursor: pointer;
    font-size: 1rem;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    gap: 4px;
    -webkit-appearance: none;
    appearance: none;
  }

  .react-btn:hover:not(.reacted) {
    transform: scale(1.2);
  }

  .react-btn.reacted {
    cursor: default;
  }

  .react-btn.react-pop {
    animation: reactPop 0.4s ease;
  }

  @keyframes reactPop {
    0% { transform: scale(1); }
    50% { transform: scale(1.3); }
    100% { transform: scale(1); }
  }

  .react-count {
    font-family: var(--font-display);
    font-size: 0.85rem;
    letter-spacing: 1px;
    color: var(--amber-glow);
  }
</style>

<script>
  function initGuestbook() {
    const form = document.getElementById('guestbook-form');
    const nameInput = document.getElementById('gb-name') as HTMLInputElement;
    const msgInput = document.getElementById('gb-message') as HTMLTextAreaElement;
    const btn = document.getElementById('gb-submit') as HTMLButtonElement;
    const status = document.getElementById('gb-status');
    const grid = document.getElementById('message-grid');
    const empty = document.getElementById('gb-empty');

    async function loadMessages() {
      try {
        const res = await fetch('/api/guestbook');
        const data = await res.json();

        if (!grid) return;

        if (!data.messages || data.messages.length === 0) {
          if (empty) empty.textContent = 'No messages yet. Be the first!';
          return;
        }

        if (empty) empty.remove();

        const reacted = JSON.parse(localStorage.getItem('oo-reacted') || '[]');

        grid.innerHTML = data.messages.map((msg: any) => {
          const date = new Date(msg.timestamp);
          const timeAgo = getTimeAgo(date);
          const safeName = escapeHtml(msg.name);
          const safeMessage = escapeHtml(msg.message);
          const reactions = msg.reactions || 0;
          const hasReacted = reacted.includes(msg.id);
          return `<div class="message-card">
            <div class="message-author">${safeName}</div>
            <div class="message-text">${safeMessage}</div>
            <div class="message-footer">
              <div class="message-time">${timeAgo}</div>
              <span class="react-btn ${hasReacted ? 'reacted' : ''}" data-id="${escapeHtml(msg.id)}">
                🧡${reactions > 0 ? ' <span class="react-count">' + reactions + '</span>' : ''}
              </span>
            </div>
          </div>`;
        }).join('');

        // Attach reaction handlers
        grid.querySelectorAll('.react-btn:not(.reacted)').forEach((btn: Element) => {
          btn.addEventListener('click', async () => {
            const id = (btn as HTMLElement).dataset.id;
            btn.classList.add('reacted');
            try {
              const res = await fetch('/api/react', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ id })
              });
              const result = await res.json();
              if (result.success) {
                const countEl = btn.querySelector('.react-count');
                if (countEl) {
                  countEl.textContent = String(result.reactions);
                } else {
                  btn.innerHTML = '🧡 <span class="react-count">' + result.reactions + '</span>';
                }
                const stored = JSON.parse(localStorage.getItem('oo-reacted') || '[]');
                stored.push(id);
                localStorage.setItem('oo-reacted', JSON.stringify(stored));
                btn.classList.add('react-pop');
              }
            } catch (e) {
              btn.classList.remove('reacted');
            }
          });
        });
      } catch (e) {
        if (empty) empty.textContent = 'Could not load messages.';
      }
    }

    function escapeHtml(text: string) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    function getTimeAgo(date: Date) {
      const seconds = Math.floor((Date.now() - date.getTime()) / 1000);
      if (seconds < 60) return 'just now';
      if (seconds < 3600) return Math.floor(seconds / 60) + ' min ago';
      if (seconds < 86400) return Math.floor(seconds / 3600) + ' hours ago';
      if (seconds < 604800) return Math.floor(seconds / 86400) + ' days ago';
      return date.toLocaleDateString();
    }

    loadMessages();

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const name = nameInput?.value?.trim();
      const message = msgInput?.value?.trim();
      if (!name || !message) return;

      if (btn) { btn.disabled = true; btn.textContent = 'POSTING...'; }
      if (status) { status.textContent = ''; status.className = 'gb-status'; }

      try {
        const res = await fetch('/api/guestbook', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, message })
        });

        const data = await res.json();

        if (data.success) {
          if (status) {
            status.textContent = 'POSTED! Thanks for the love.';
            status.className = 'gb-status success';
          }
          if (msgInput) msgInput.value = '';
          if (window.fireConfetti) window.fireConfetti();
          loadMessages();
        } else {
          if (status) {
            status.textContent = data.error || 'Something went wrong';
            status.className = 'gb-status error';
          }
        }
      } catch (err) {
        if (status) {
          status.textContent = 'Could not connect. Try again later.';
          status.className = 'gb-status error';
        }
      }

      if (btn) { btn.disabled = false; btn.textContent = 'POST TO THE WALL'; }
    });
  }

  initGuestbook();
  document.addEventListener('astro:after-swap', initGuestbook);
</script>
