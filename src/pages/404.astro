---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Lost in the Citrus">
  <section class="error-page">
    <div class="emoji-rain" id="emojiRain"></div>
    <div class="error-content">
      <span class="error-code">404</span>
      <h1 class="error-title">LOST IN THE CITRUS</h1>
      <p class="error-subtitle">
        This page got lost somewhere between the orange and the oreo.
        <br>Maybe it's hanging out with Addy's missing socks.
      </p>
      <a href="/" class="btn btn-primary">BACK TO HOME →</a>
    </div>
  </section>
</Layout>

<style>
  .error-page {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--black);
    text-align: center;
    padding: 40px;
    position: relative;
    overflow: hidden;
  }

  .error-content {
    max-width: 600px;
    position: relative;
    z-index: 1;
  }

  .error-code {
    font-family: var(--font-display);
    font-size: clamp(8rem, 20vw, 16rem);
    background: linear-gradient(135deg, var(--amber-glow), var(--honey-bronze), var(--sea-green-light));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    line-height: 1;
    display: block;
    opacity: 0.5;
    animation: errorPulse 3s ease-in-out infinite;
  }

  @keyframes errorPulse {
    0%, 100% { transform: scale(1); opacity: 0.5; }
    50% { transform: scale(1.03); opacity: 0.7; }
  }

  .error-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    color: var(--white);
    letter-spacing: 4px;
    margin-top: -20px;
  }

  .error-subtitle {
    color: rgba(255, 255, 255, 0.5);
    margin: 24px 0 48px;
    font-size: 1.1rem;
    line-height: 1.6;
  }
</style>

<script is:inline>
  (function() {
    const container = document.getElementById('emojiRain');
    if (!container) return;
    const emojis = ['🍊', '🍪', '⭐', '✨', '🎵', '🎶'];
    for (let i = 0; i < 20; i++) {
      const el = document.createElement('span');
      el.className = 'rain-emoji';
      el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
      el.style.left = Math.random() * 100 + '%';
      el.style.animationDuration = (Math.random() * 4 + 4) + 's';
      el.style.animationDelay = (Math.random() * 6) + 's';
      el.style.fontSize = (Math.random() * 1.5 + 1) + 'rem';
      el.style.opacity = Math.random() * 0.4 + 0.2;
      container.appendChild(el);
    }
  })();
</script>
